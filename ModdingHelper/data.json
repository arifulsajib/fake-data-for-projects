          "id": "remove_ads",
          "order": 1,

          "type": "common_mod",

          "title": "Remove Ads",

          "shortDescription": "Disable ad loading.",

          "description": "Replace the ad loading instruction with return-void.",

          "language": "Smali",

          "difficulty": "Medium",

          "tags": [
            "ads",
            "patch"
          ],

          "keywords": [
            "admob",
            "loadAd"
          ],

          "notes": "Always backup before editing.",

          "searchCode": "invoke-virtual {p0}, Lcom/google/android/gms/ads/AdView;->loadAd(Lcom/google/android/gms/ads/AdRequest;)V",

          "replaceCode": "return-void"
        }, 
        {
          "id": "remove_country_restrictions_1",
          "order": 2,
          "type": "common_mod",
          "title": "Remove Country Restrictions (Regex 1)",
          "shortDescription": "Replace network operator name with T-Mobile.",
          "description": "Overrides the returned network operator name to bypass region checks.",
          "language": "Regex / Smali",
          "difficulty": "Medium",
          "tags": [
            "country",
            "region",
            "regex"
          ],
          "keywords": [
            "getNetworkOperatorName",
            "getSimOperatorName",
            "T-Mobile"
          ],
          "notes": "Create a backup before applying.",
          "searchCode": "(getNetworkOperatorName|getSimOperatorName).+Ljava.lang.String;\\n\\n\\s{4}move-result-object ([vlp]\\d+)",
          "replaceCode": "$1()Ljava/lang/String;\\n\\n\\ \\ \\ \\ const-string $2, \"T-Mobile\""
        },
        {
          "id": "remove_country_restrictions_2",
          "order": 3,
          "type": "common_mod",
          "title": "Remove Country Restrictions (Regex 2)",
          "shortDescription": "Replace network operator code with 310160.",
          "description": "Overrides the returned network operator code.",
          "language": "Regex / Smali",
          "difficulty": "Medium",
          "tags": [
            "country",
            "region",
            "regex"
          ],
          "keywords": [
            "getSimOperator",
            "getNetworkOperator",
            "310160"
          ],
          "notes": "Create a backup before applying.",
          "searchCode": "(getSimOperator|getNetworkOperator).+Ljava.lang.String;\\n\\n\\s{4}move-result-object ([vlp]\\d+)",
          "replaceCode": "$1()Ljava/lang/String;\\n\\n\\ \\ \\ \\ const-string $2, \"310160\""
        },
        {
          "id": "remove_country_restrictions_3",
          "order": 4,
          "type": "common_mod",
          "title": "Remove Country Restrictions (Regex 3)",
          "shortDescription": "Replace country ISO with us.",
          "description": "Overrides the returned country ISO code.",
          "language": "Regex / Smali",
          "difficulty": "Medium",
          "tags": [
            "country",
            "region",
            "regex"
          ],
          "keywords": [
            "getSimCountryIso",
            "getNetworkCountryIso",
            "us"
          ],
