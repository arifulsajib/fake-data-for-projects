          "language": "Smali",
          "difficulty": "Easy",
          "tags": ["return", "method"],
          "keywords": ["return-void", "exit"],
          "notes": "Only for void methods.",
          "code": "return-void"
        },
        {
          "id": "return_true",
          "order": 4,
          "type": "snippet",
          "title": "Return True",
          "shortDescription": "Return boolean TRUE.",
          "description": "Returns true from a boolean method.",
