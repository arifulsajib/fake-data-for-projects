          "difficulty": "Easy",

          "tags": [
            "boolean",
            "premium",
            "bypass"
          ],

          "keywords": [
            "true",
            "const/4",
            "premium"
          ],

          "notes": "Verify register before replacing.",

          "code": "const/4 v0, 0x1"
        }, 
        {
          "id": "always_false",
          "order": 2,
          "type": "snippet",

          "title": "Always False",

