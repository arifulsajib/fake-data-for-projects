          "title": "Load String",
          "shortDescription": "Load a string constant.",
          "description": "Stores a string into a register.",
          "language": "Smali",
          "difficulty": "Easy",
          "tags": ["string"],
          "keywords": ["const-string", "text"],
          "notes": "Useful for displaying or comparing strings.",
          "code": "const-string v0, \"Hello World\""
        },
        {
          "id": "const_number",
          "order": 7,
          "type": "snippet",
          "title": "Load Integer",
          "shortDescription": "Load an integer constant.",
