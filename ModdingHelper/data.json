        {
          "id": "move_result",
          "order": 8,
          "type": "snippet",
          "title": "Move Result",
          "shortDescription": "Store a method result.",
          "description": "Gets the value returned by the previous method call.",
          "language": "Smali",
          "difficulty": "Medium",
          "tags": ["invoke"],
          "keywords": ["move-result"],
          "notes": "Must follow invoke-*.",
          "code": "invoke-virtual {p0}, Ljava/lang/String;->length()I\nmove-result v0"
        },
        {
          "id": "new_instance",
          "order": 9,
          "type": "snippet",
          "title": "Create Object",
          "shortDescription": "Create a new object.",
