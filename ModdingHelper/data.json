          "language": "Smali",
          "difficulty": "Medium",
          "tags": ["object"],
          "keywords": ["new-instance"],
          "notes": "Always call invoke-direct after new-instance.",
          "code": "new-instance v0, Ljava/lang/StringBuilder;\ninvoke-direct {v0}, Ljava/lang/StringBuilder;-><init>()V"
